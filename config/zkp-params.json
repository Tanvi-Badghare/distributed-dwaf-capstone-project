{
  "version": "1.0",
  "proof_system": "groth16",
  "curve": "bn254",
  "security_level_bits": 128,

  "circuit": {
    "name": "ml_inference",
    "version": "v1",
    "public_inputs": [
      "threat_flag",
      "confidence_bucket"
    ]
  },

  "trusted_setup": {
    "proving_key_path": "params/proving_key.bin",
    "verifying_key_path": "params/verification_key.bin",
    "setup_hash": "REPLACE_WITH_GENERATED_HASH"
  },

  "proof_generation": {
    "timeout_seconds": 15,
    "aggregation_enabled": false
  }
}
